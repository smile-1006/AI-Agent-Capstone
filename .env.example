# Server
APP_ENV=development
PORT=8000

# Security
JWT_SECRET=change-me-super-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRES_MINUTES=60

# Rate limiting (requests per minute)
RATE_LIMIT_PER_MINUTE=120

# Database
DATABASE_URL=sqlite:///./database/sqlite.db

# Observability
LOG_LEVEL=INFO

# Embeddings (placeholder provider config; implementation is local-safe)
EMBEDDINGS_DIM=384
EMBEDDINGS_TOP_K=5

# External Tooling
WEB_SEARCH_API_URL=https://example.com
WEATHER_API_URL=https://example.com
OPENWEATHER_API_KEY=
OPENWEATHER_GEOCODE_URL=https://api.openweathermap.org/geo/1.0/direct
OPENWEATHER_FORECAST_URL=https://api.openweathermap.org/data/2.5/forecast/daily
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

